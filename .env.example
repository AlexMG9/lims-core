# =====================================================
# LIMS-CORE — Environment Variables Example
# =====================================================
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must never be committed.

# --- MySQL Database Configuration ---
# Used by both the MySQL container and the backend.
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=lims_db
MYSQL_USER=lims_user
MYSQL_PASSWORD=change_me_user_password

# --- Backend JWT Secret Key ---
# Generate a secure random key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse this value across environments.
SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets.token_hex_32
